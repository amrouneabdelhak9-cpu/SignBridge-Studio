                color: {TEXT_SECONDARY};
            }}
        """)
        buf_clear.clicked.connect(self._clear_all)
        footer.addWidget(buf_clear, 0, Qt.AlignVCenter)
        layout.addLayout(footer)

        return panel

    # ──────────────────────────────────────────
    # Voice Synthesis Panel (expanded & centered)
